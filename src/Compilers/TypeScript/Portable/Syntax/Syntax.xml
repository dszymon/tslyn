<Tree Root="SyntaxNode">
  <PredefinedNode Name="TypeScriptSyntaxNode" Base="SyntaxNode"/>
  <PredefinedNode Name="SyntaxToken" Base="TypeScriptSyntaxNode"/>
  <PredefinedNode Name="SyntaxTrivia" Base="TypeScriptSyntaxNode"/>

  <!-- Base Classes -->
  <AbstractNode Name="StatementSyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <AbstractNode Name="ExpressionSyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <AbstractNode Name="TypeSyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <AbstractNode Name="DeclarationSyntax" Base="StatementSyntax">
      <Field Name="Modifiers" Type="SyntaxTokenList" Optional="true"/>
      <Field Name="Decorators" Type="SyntaxList&lt;DecoratorSyntax&gt;" Optional="true"/>
  </AbstractNode>

  <AbstractNode Name="TypeElementSyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <AbstractNode Name="ModuleBodySyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <!-- Common Structures -->
  <Node Name="IdentifierNameSyntax" Base="ExpressionSyntax">
    <Kind Name="IdentifierName"/>
    <Field Name="Identifier" Type="SyntaxToken">
        <Kind Name="IdentifierToken"/>
    </Field>
  </Node>

  <Node Name="QualifiedNameSyntax" Base="ExpressionSyntax">
      <Kind Name="QualifiedName"/>
      <Field Name="Left" Type="ExpressionSyntax"/>
      <Field Name="DotToken" Type="SyntaxToken">
          <Kind Name="DotToken"/>
      </Field>
      <Field Name="Right" Type="IdentifierNameSyntax"/>
  </Node>

  <Node Name="DecoratorSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="Decorator"/>
      <Field Name="AtToken" Type="SyntaxToken">
          <Kind Name="AtToken"/>
      </Field>
      <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="TypeParameterListSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="TypeParameterList"/>
      <Field Name="LessThanToken" Type="SyntaxToken">
          <Kind Name="LessThanToken"/>
      </Field>
      <Field Name="Parameters" Type="SeparatedSyntaxList&lt;TypeParameterSyntax&gt;"/>
      <Field Name="GreaterThanToken" Type="SyntaxToken">
          <Kind Name="GreaterThanToken"/>
      </Field>
  </Node>

  <Node Name="TypeParameterSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="TypeParameter"/>
      <Field Name="Name" Type="IdentifierNameSyntax"/>
      <Field Name="Constraint" Type="TypeSyntax" Optional="true"/>
      <Field Name="Default" Type="TypeSyntax" Optional="true"/>
  </Node>

  <Node Name="ParameterListSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="ParameterList"/>
      <Field Name="OpenParenToken" Type="SyntaxToken">
          <Kind Name="OpenParenToken"/>
      </Field>
      <Field Name="Parameters" Type="SeparatedSyntaxList&lt;ParameterSyntax&gt;"/>
      <Field Name="CloseParenToken" Type="SyntaxToken">
          <Kind Name="CloseParenToken"/>
      </Field>
  </Node>

  <Node Name="ParameterSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="Parameter"/>
      <Field Name="Decorators" Type="SyntaxList&lt;DecoratorSyntax&gt;" Optional="true"/>
      <Field Name="Modifiers" Type="SyntaxTokenList" Optional="true"/>
      <Field Name="DotDotDotToken" Type="SyntaxToken" Optional="true">
          <Kind Name="DotDotDotToken"/>
      </Field>
      <Field Name="Name" Type="BindingNameSyntax"/>
      <Field Name="QuestionToken" Type="SyntaxToken" Optional="true">
          <Kind Name="QuestionToken"/>
      </Field>
      <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
      <Field Name="Initializer" Type="EqualsValueClauseSyntax" Optional="true"/>
  </Node>

  <!-- Declarations -->
  <Node Name="ClassDeclarationSyntax" Base="DeclarationSyntax">
      <Kind Name="ClassDeclaration"/>
      <Field Name="ClassKeyword" Type="SyntaxToken">
          <Kind Name="ClassKeyword"/>
      </Field>
      <Field Name="Identifier" Type="SyntaxToken" Optional="true">
          <Kind Name="IdentifierToken"/>
      </Field>
      <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
      <Field Name="HeritageClauses" Type="SyntaxList&lt;HeritageClauseSyntax&gt;" Optional="true"/>
      <Field Name="OpenBraceToken" Type="SyntaxToken">
          <Kind Name="OpenBraceToken"/>
      </Field>
      <Field Name="Members" Type="SyntaxList&lt;TypeElementSyntax&gt;"/>
      <Field Name="CloseBraceToken" Type="SyntaxToken">
          <Kind Name="CloseBraceToken"/>
      </Field>
  </Node>

  <Node Name="InterfaceDeclarationSyntax" Base="DeclarationSyntax">
      <Kind Name="InterfaceDeclaration"/>
      <Field Name="InterfaceKeyword" Type="SyntaxToken">
          <Kind Name="InterfaceKeyword"/>
      </Field>
      <Field Name="Identifier" Type="SyntaxToken">
          <Kind Name="IdentifierToken"/>
      </Field>
      <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
      <Field Name="HeritageClauses" Type="SyntaxList&lt;HeritageClauseSyntax&gt;" Optional="true"/>
      <Field Name="OpenBraceToken" Type="SyntaxToken">
          <Kind Name="OpenBraceToken"/>
      </Field>
      <Field Name="Members" Type="SyntaxList&lt;TypeElementSyntax&gt;"/>
      <Field Name="CloseBraceToken" Type="SyntaxToken">
          <Kind Name="CloseBraceToken"/>
      </Field>
  </Node>

  <Node Name="EnumDeclarationSyntax" Base="DeclarationSyntax">
      <Kind Name="EnumDeclaration"/>
      <Field Name="EnumKeyword" Type="SyntaxToken">
          <Kind Name="EnumKeyword"/>
      </Field>
      <Field Name="Identifier" Type="SyntaxToken">
          <Kind Name="IdentifierToken"/>
      </Field>
      <Field Name="OpenBraceToken" Type="SyntaxToken">
          <Kind Name="OpenBraceToken"/>
      </Field>
      <Field Name="Members" Type="SeparatedSyntaxList&lt;EnumMemberSyntax&gt;"/>
      <Field Name="CloseBraceToken" Type="SyntaxToken">
          <Kind Name="CloseBraceToken"/>
      </Field>
  </Node>

  <Node Name="EnumMemberSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="EnumMember"/>
      <Field Name="Name" Type="PropertyNameSyntax"/>
      <Field Name="Initializer" Type="EqualsValueClauseSyntax" Optional="true"/>
  </Node>

  <Node Name="ModuleDeclarationSyntax" Base="DeclarationSyntax">
      <Kind Name="ModuleDeclaration"/>
      <Field Name="Keyword" Type="SyntaxToken">
          <Kind Name="ModuleKeyword"/>
          <Kind Name="NamespaceKeyword"/>
      </Field>
      <Field Name="Name" Type="ExpressionSyntax"/> <!-- Identifier or StringLiteral -->
      <Field Name="Body" Type="ModuleBodySyntax"/> <!-- ModuleBlock or NamespaceDeclaration -->
  </Node>

  <Node Name="ModuleBlockSyntax" Base="ModuleBodySyntax">
      <Kind Name="ModuleBlock"/>
      <Field Name="OpenBraceToken" Type="SyntaxToken">
          <Kind Name="OpenBraceToken"/>
      </Field>
      <Field Name="Statements" Type="SyntaxList&lt;StatementSyntax&gt;"/>
      <Field Name="CloseBraceToken" Type="SyntaxToken">
          <Kind Name="CloseBraceToken"/>
      </Field>
  </Node>

  <Node Name="FunctionDeclarationSyntax" Base="DeclarationSyntax">
      <Kind Name="FunctionDeclaration"/>
      <Field Name="FunctionKeyword" Type="SyntaxToken">
          <Kind Name="FunctionKeyword"/>
      </Field>
      <Field Name="AsteriskToken" Type="SyntaxToken" Optional="true">
          <Kind Name="AsteriskToken"/>
      </Field>
      <Field Name="Identifier" Type="SyntaxToken" Optional="true">
          <Kind Name="IdentifierToken"/>
      </Field>
      <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
      <Field Name="Parameters" Type="ParameterListSyntax"/>
      <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
      <Field Name="Body" Type="BlockSyntax" Optional="true"/>
      <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
          <Kind Name="SemicolonToken"/>
      </Field>
  </Node>

  <Node Name="ImportDeclarationSyntax" Base="StatementSyntax">
      <Kind Name="ImportDeclaration"/>
      <Field Name="ImportKeyword" Type="SyntaxToken">
          <Kind Name="ImportKeyword"/>
      </Field>
      <Field Name="ImportClause" Type="ImportClauseSyntax" Optional="true"/>
      <Field Name="FromKeyword" Type="SyntaxToken" Optional="true"> <!-- Optional for side-effect imports -->
          <Kind Name="FromKeyword"/>
      </Field>
      <Field Name="ModuleSpecifier" Type="ExpressionSyntax"/> <!-- StringLiteral -->
      <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
          <Kind Name="SemicolonToken"/>
      </Field>
  </Node>

  <Node Name="ImportClauseSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="ImportSpecifier"/>
      <!-- Logic for named imports vs namespace imports vs default is complex, simplified here -->
      <Field Name="Name" Type="IdentifierNameSyntax" Optional="true"/> <!-- Default import -->
      <Field Name="NamedImports" Type="NamedImportsSyntax" Optional="true"/>
      <Field Name="NamespaceImport" Type="NamespaceImportSyntax" Optional="true"/>
  </Node>

  <Node Name="NamedImportsSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="NamedImports"/>
      <Field Name="OpenBraceToken" Type="SyntaxToken">
          <Kind Name="OpenBraceToken"/>
      </Field>
      <Field Name="Elements" Type="SeparatedSyntaxList&lt;ImportSpecifierSyntax&gt;"/>
      <Field Name="CloseBraceToken" Type="SyntaxToken">
          <Kind Name="CloseBraceToken"/>
      </Field>
  </Node>

  <Node Name="ImportSpecifierSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="ImportSpecifier"/>
      <Field Name="PropertyName" Type="IdentifierNameSyntax" Optional="true"/>
      <Field Name="AsKeyword" Type="SyntaxToken" Optional="true">
          <Kind Name="AsKeyword"/>
      </Field>
      <Field Name="Name" Type="IdentifierNameSyntax"/>
  </Node>

  <Node Name="NamespaceImportSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="ExternalModuleReference"/> <!-- Reusing existing kind or need new one -->
      <Field Name="AsteriskToken" Type="SyntaxToken">
          <Kind Name="AsteriskToken"/>
      </Field>
      <Field Name="AsKeyword" Type="SyntaxToken">
          <Kind Name="AsKeyword"/>
      </Field>
      <Field Name="Name" Type="IdentifierNameSyntax"/>
  </Node>

  <Node Name="ExportDeclarationSyntax" Base="StatementSyntax">
      <Kind Name="ExportDeclaration"/>
      <Field Name="ExportKeyword" Type="SyntaxToken">
          <Kind Name="ExportKeyword"/>
      </Field>
      <Field Name="ExportClause" Type="NamedExportsSyntax" Optional="true"/>
      <Field Name="FromKeyword" Type="SyntaxToken" Optional="true">
          <Kind Name="FromKeyword"/>
      </Field>
      <Field Name="ModuleSpecifier" Type="ExpressionSyntax" Optional="true"/>
      <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
          <Kind Name="SemicolonToken"/>
      </Field>
  </Node>

  <Node Name="NamedExportsSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="NamedExports"/>
      <Field Name="OpenBraceToken" Type="SyntaxToken">
          <Kind Name="OpenBraceToken"/>
      </Field>
      <Field Name="Elements" Type="SeparatedSyntaxList&lt;ExportSpecifierSyntax&gt;"/>
      <Field Name="CloseBraceToken" Type="SyntaxToken">
          <Kind Name="CloseBraceToken"/>
      </Field>
  </Node>

  <Node Name="ExportSpecifierSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="ExportSpecifier"/>
      <Field Name="PropertyName" Type="IdentifierNameSyntax" Optional="true"/>
      <Field Name="AsKeyword" Type="SyntaxToken" Optional="true">
          <Kind Name="AsKeyword"/>
      </Field>
      <Field Name="Name" Type="IdentifierNameSyntax"/>
  </Node>

  <Node Name="HeritageClauseSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="HeritageClause"/>
      <Field Name="Keyword" Type="SyntaxToken">
          <Kind Name="ExtendsKeyword"/>
          <Kind Name="ImplementsKeyword"/>
      </Field>
      <Field Name="Types" Type="SeparatedSyntaxList&lt;ExpressionWithTypeArgumentsSyntax&gt;"/>
  </Node>

  <Node Name="ExpressionWithTypeArgumentsSyntax" Base="TypeSyntax">
      <Kind Name="ExpressionWithTypeArguments"/>
      <Field Name="Expression" Type="ExpressionSyntax"/>
      <Field Name="TypeArguments" Type="TypeArgumentListSyntax" Optional="true"/>
  </Node>

  <Node Name="TypeArgumentListSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="TypeArgumentList"/>
      <Field Name="LessThanToken" Type="SyntaxToken">
          <Kind Name="LessThanToken"/>
      </Field>
      <Field Name="Arguments" Type="SeparatedSyntaxList&lt;TypeSyntax&gt;"/>
      <Field Name="GreaterThanToken" Type="SyntaxToken">
          <Kind Name="GreaterThanToken"/>
      </Field>
  </Node>

  <Node Name="TypeAliasDeclarationSyntax" Base="DeclarationSyntax">
      <Kind Name="TypeAliasDeclaration"/>
      <Field Name="TypeKeyword" Type="SyntaxToken">
          <Kind Name="TypeKeyword"/>
      </Field>
      <Field Name="Identifier" Type="SyntaxToken">
          <Kind Name="IdentifierToken"/>
      </Field>
      <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
      <Field Name="EqualsToken" Type="SyntaxToken">
          <Kind Name="EqualsToken"/>
      </Field>
      <Field Name="Type" Type="TypeSyntax"/>
      <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
          <Kind Name="SemicolonToken"/>
      </Field>
  </Node>

  <Node Name="VariableStatementSyntax" Base="StatementSyntax">
      <Kind Name="VariableStatement"/>
      <Field Name="DeclarationList" Type="VariableDeclarationListSyntax"/>
      <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
           <Kind Name="SemicolonToken"/>
      </Field>
  </Node>

  <Node Name="VariableDeclarationListSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="VariableDeclarationList"/>
      <Field Name="Keyword" Type="SyntaxToken">
           <Kind Name="VarKeyword"/>
           <Kind Name="LetKeyword"/>
           <Kind Name="ConstKeyword"/>
      </Field>
      <Field Name="Declarations" Type="SeparatedSyntaxList&lt;VariableDeclarationSyntax&gt;"/>
  </Node>

  <Node Name="VariableDeclarationSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="VariableDeclaration"/>
      <Field Name="Name" Type="BindingNameSyntax"/> <!-- Identifier or BindingPattern -->
      <Field Name="ExclamationToken" Type="SyntaxToken" Optional="true">
          <Kind Name="ExclamationToken"/>
      </Field>
      <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
      <Field Name="Initializer" Type="EqualsValueClauseSyntax" Optional="true"/>
  </Node>

  <Node Name="TypeAnnotationSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="TypeAnnotation"/>
      <Field Name="ColonToken" Type="SyntaxToken">
          <Kind Name="ColonToken"/>
      </Field>
      <Field Name="Type" Type="TypeSyntax"/>
  </Node>

  <Node Name="EqualsValueClauseSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="EqualsValueClause"/>
      <Field Name="EqualsToken" Type="SyntaxToken">
          <Kind Name="EqualsToken"/>
      </Field>
      <Field Name="Value" Type="ExpressionSyntax"/>
  </Node>

  <AbstractNode Name="BindingNameSyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <!-- BindingName can be IdentifierName or BindingPattern (Object/Array) -->
  <Node Name="BindingIdentifierSyntax" Base="BindingNameSyntax">
      <Kind Name="Identifier"/>
      <Field Name="Identifier" Type="SyntaxToken"/>
  </Node>

  <AbstractNode Name="PropertyNameSyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <!-- Types -->
  <Node Name="UnionTypeSyntax" Base="TypeSyntax">
      <Kind Name="UnionType"/>
      <Field Name="Types" Type="SeparatedSyntaxList&lt;TypeSyntax&gt;"/>
  </Node>

  <Node Name="IntersectionTypeSyntax" Base="TypeSyntax">
      <Kind Name="IntersectionType"/>
      <Field Name="Types" Type="SeparatedSyntaxList&lt;TypeSyntax&gt;"/>
  </Node>

  <Node Name="PredefinedTypeSyntax" Base="TypeSyntax">
      <Kind Name="PredefinedType"/>
      <Field Name="Keyword" Type="SyntaxToken"/>
  </Node>

  <Node Name="ArrayTypeSyntax" Base="TypeSyntax">
      <Kind Name="ArrayType"/>
      <Field Name="ElementType" Type="TypeSyntax"/>
      <Field Name="OpenBracketToken" Type="SyntaxToken">
          <Kind Name="OpenBracketToken"/>
      </Field>
      <Field Name="CloseBracketToken" Type="SyntaxToken">
          <Kind Name="CloseBracketToken"/>
      </Field>
  </Node>

  <Node Name="TupleTypeSyntax" Base="TypeSyntax">
      <Kind Name="TupleType"/>
      <Field Name="OpenBracketToken" Type="SyntaxToken">
          <Kind Name="OpenBracketToken"/>
      </Field>
      <Field Name="Elements" Type="SeparatedSyntaxList&lt;TypeSyntax&gt;"/>
      <Field Name="CloseBracketToken" Type="SyntaxToken">
          <Kind Name="CloseBracketToken"/>
      </Field>
  </Node>

  <!-- Statements -->
  <Node Name="BlockSyntax" Base="StatementSyntax">
      <Kind Name="Block"/>
      <Field Name="OpenBraceToken" Type="SyntaxToken">
          <Kind Name="OpenBraceToken"/>
      </Field>
      <Field Name="Statements" Type="SyntaxList&lt;StatementSyntax&gt;"/>
      <Field Name="CloseBraceToken" Type="SyntaxToken">
          <Kind Name="CloseBraceToken"/>
      </Field>
  </Node>

  <Node Name="ReturnStatementSyntax" Base="StatementSyntax">
      <Kind Name="ReturnStatement"/>
      <Field Name="ReturnKeyword" Type="SyntaxToken">
          <Kind Name="ReturnKeyword"/>
      </Field>
      <Field Name="Expression" Type="ExpressionSyntax" Optional="true"/>
      <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
           <Kind Name="SemicolonToken"/>
      </Field>
  </Node>

  <Node Name="IfStatementSyntax" Base="StatementSyntax">
      <Kind Name="IfStatement"/>
      <Field Name="IfKeyword" Type="SyntaxToken">
          <Kind Name="IfKeyword"/>
      </Field>
      <Field Name="OpenParenToken" Type="SyntaxToken">
          <Kind Name="OpenParenToken"/>
      </Field>
      <Field Name="Condition" Type="ExpressionSyntax"/>
      <Field Name="CloseParenToken" Type="SyntaxToken">
          <Kind Name="CloseParenToken"/>
      </Field>
      <Field Name="Statement" Type="StatementSyntax"/>
      <Field Name="ElseClause" Type="ElseClauseSyntax" Optional="true"/>
  </Node>

  <Node Name="ElseClauseSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="ElseClause"/>
      <Field Name="ElseKeyword" Type="SyntaxToken">
          <Kind Name="ElseKeyword"/>
      </Field>
      <Field Name="Statement" Type="StatementSyntax"/>
  </Node>

  <Node Name="DoStatementSyntax" Base="StatementSyntax">
      <Kind Name="DoStatement"/>
      <Field Name="DoKeyword" Type="SyntaxToken">
          <Kind Name="DoKeyword"/>
      </Field>
      <Field Name="Statement" Type="StatementSyntax"/>
      <Field Name="WhileKeyword" Type="SyntaxToken">
          <Kind Name="WhileKeyword"/>
      </Field>
      <Field Name="OpenParenToken" Type="SyntaxToken">
          <Kind Name="OpenParenToken"/>
      </Field>
      <Field Name="Condition" Type="ExpressionSyntax"/>
      <Field Name="CloseParenToken" Type="SyntaxToken">
          <Kind Name="CloseParenToken"/>
      </Field>
      <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
          <Kind Name="SemicolonToken"/>
      </Field>
  </Node>

  <Node Name="WhileStatementSyntax" Base="StatementSyntax">
      <Kind Name="WhileStatement"/>
      <Field Name="WhileKeyword" Type="SyntaxToken">
          <Kind Name="WhileKeyword"/>
      </Field>
      <Field Name="OpenParenToken" Type="SyntaxToken">
          <Kind Name="OpenParenToken"/>
      </Field>
      <Field Name="Condition" Type="ExpressionSyntax"/>
      <Field Name="CloseParenToken" Type="SyntaxToken">
          <Kind Name="CloseParenToken"/>
      </Field>
      <Field Name="Statement" Type="StatementSyntax"/>
  </Node>

  <Node Name="ForStatementSyntax" Base="StatementSyntax">
      <Kind Name="ForStatement"/>
      <Field Name="ForKeyword" Type="SyntaxToken">
          <Kind Name="ForKeyword"/>
      </Field>
      <Field Name="OpenParenToken" Type="SyntaxToken">
          <Kind Name="OpenParenToken"/>
      </Field>
      <Field Name="Initializer" Type="ForInitializerSyntax" Optional="true"/>
      <Field Name="FirstSemicolonToken" Type="SyntaxToken">
          <Kind Name="SemicolonToken"/>
      </Field>
      <Field Name="Condition" Type="ExpressionSyntax" Optional="true"/>
      <Field Name="SecondSemicolonToken" Type="SyntaxToken">
          <Kind Name="SemicolonToken"/>
      </Field>
      <Field Name="Incrementor" Type="ExpressionSyntax" Optional="true"/>
      <Field Name="CloseParenToken" Type="SyntaxToken">
          <Kind Name="CloseParenToken"/>
      </Field>
      <Field Name="Statement" Type="StatementSyntax"/>
  </Node>

  <AbstractNode Name="ForInitializerSyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <Node Name="ForStatementVariableDeclarationSyntax" Base="ForInitializerSyntax">
      <Kind Name="VariableDeclarationList"/>
      <Field Name="DeclarationList" Type="VariableDeclarationListSyntax"/>
  </Node>

  <Node Name="ForStatementExpressionSyntax" Base="ForInitializerSyntax">
      <Kind Name="ExpressionStatement"/> <!-- Simplified -->
      <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <!-- Expressions -->
  <Node Name="BinaryExpressionSyntax" Base="ExpressionSyntax">
      <Kind Name="BinaryExpression"/>
      <Field Name="Left" Type="ExpressionSyntax"/>
      <Field Name="OperatorToken" Type="SyntaxToken"/>
      <Field Name="Right" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="LiteralExpressionSyntax" Base="ExpressionSyntax">
      <Kind Name="NumericLiteralExpression"/>
      <Kind Name="StringLiteralExpression"/>
      <Kind Name="TrueLiteralExpression"/>
      <Kind Name="FalseLiteralExpression"/>
      <Kind Name="NullLiteralExpression"/>
      <Field Name="Token" Type="SyntaxToken"/>
  </Node>

  <Node Name="CallExpressionSyntax" Base="ExpressionSyntax">
      <Kind Name="CallExpression"/>
      <Field Name="Expression" Type="ExpressionSyntax"/>
      <Field Name="TypeArguments" Type="TypeArgumentListSyntax" Optional="true"/>
      <Field Name="OpenParenToken" Type="SyntaxToken">
          <Kind Name="OpenParenToken"/>
      </Field>
      <Field Name="Arguments" Type="SeparatedSyntaxList&lt;ExpressionSyntax&gt;"/>
      <Field Name="CloseParenToken" Type="SyntaxToken">
          <Kind Name="CloseParenToken"/>
      </Field>
  </Node>

  <Node Name="ArrowFunctionSyntax" Base="ExpressionSyntax">
      <Kind Name="ArrowFunction"/>
      <Field Name="Modifiers" Type="SyntaxTokenList" Optional="true"/>
      <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
      <Field Name="Parameters" Type="ParameterListSyntax"/>
      <Field Name="ReturnType" Type="TypeAnnotationSyntax" Optional="true"/>
      <Field Name="EqualsGreaterThanToken" Type="SyntaxToken">
          <Kind Name="EqualsGreaterThanToken"/>
      </Field>
      <Field Name="Body" Type="ExpressionOrBlockSyntax"/>
  </Node>

  <AbstractNode Name="ExpressionOrBlockSyntax" Base="TypeScriptSyntaxNode">
  </AbstractNode>

  <Node Name="ConciseBodyBlockSyntax" Base="ExpressionOrBlockSyntax">
      <Kind Name="Block"/>
      <Field Name="Block" Type="BlockSyntax"/>
  </Node>

  <Node Name="ConciseBodyExpressionSyntax" Base="ExpressionOrBlockSyntax">
      <Kind Name="ExpressionStatement"/>
      <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <!-- Compilation Unit -->
  <Node Name="SourceFileSyntax" Base="TypeScriptSyntaxNode">
      <Kind Name="SourceFile"/>
      <Field Name="Statements" Type="SyntaxList&lt;StatementSyntax&gt;"/>
      <Field Name="EndOfFileToken" Type="SyntaxToken">
          <Kind Name="EndOfFileToken"/>
      </Field>
  </Node>

</Tree>
