<?xml version="1.0" encoding="utf-8"?>
<Tree Root="SyntaxNode">
  <PredefinedNode Name="TypeScriptSyntaxNode" Base="SyntaxNode"/>
  <PredefinedNode Name="SyntaxToken" Base="TypeScriptSyntaxNode"/>
  <PredefinedNode Name="StructuredTriviaSyntax" Base="TypeScriptSyntaxNode"/>

  <!-- Abstract Bases -->
  <AbstractNode Name="ExpressionSyntax" Base="TypeScriptSyntaxNode"/>
  <AbstractNode Name="StatementSyntax" Base="TypeScriptSyntaxNode"/>
  <AbstractNode Name="TypeSyntax" Base="ExpressionSyntax"/>
  <AbstractNode Name="DeclarationStatementSyntax" Base="StatementSyntax"/>
  <AbstractNode Name="TypeElementSyntax" Base="TypeScriptSyntaxNode"/>
  <AbstractNode Name="ClassElementSyntax" Base="TypeScriptSyntaxNode"/>

  <!-- Expressions -->
  <Node Name="IdentifierNameSyntax" Base="TypeSyntax">
    <Kind Name="IdentifierName"/>
    <Field Name="Identifier" Type="SyntaxToken">
      <Kind Name="IdentifierToken"/>
    </Field>
  </Node>

  <Node Name="LiteralExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="NumericLiteralExpression"/>
    <Kind Name="StringLiteralExpression"/>
    <Kind Name="TrueLiteralExpression"/>
    <Kind Name="FalseLiteralExpression"/>
    <Kind Name="NullLiteralExpression"/>
    <Field Name="Token" Type="SyntaxToken"/>
  </Node>

  <Node Name="BinaryExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="AddExpression"/>
    <Kind Name="SubtractExpression"/>
    <Kind Name="MultiplyExpression"/>
    <Kind Name="DivideExpression"/>
    <Kind Name="EqualsExpression"/>
    <Kind Name="NotEqualsExpression"/>
    <Kind Name="LessThanExpression"/>
    <Kind Name="LessThanOrEqualExpression"/>
    <Kind Name="GreaterThanExpression"/>
    <Kind Name="GreaterThanOrEqualExpression"/>
    <Kind Name="LogicalAndExpression"/>
    <Kind Name="LogicalOrExpression"/>
    <Kind Name="AssignmentExpression"/>
    <Field Name="Left" Type="ExpressionSyntax"/>
    <Field Name="OperatorToken" Type="SyntaxToken"/>
    <Field Name="Right" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="MemberAccessExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="MemberAccessExpression"/>
    <Field Name="Expression" Type="ExpressionSyntax"/>
    <Field Name="DotToken" Type="SyntaxToken">
        <Kind Name="DotToken"/>
    </Field>
    <Field Name="Name" Type="IdentifierNameSyntax"/>
  </Node>

  <Node Name="PrefixUnaryExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="PrefixUnaryExpression"/>
    <Field Name="OperatorToken" Type="SyntaxToken"/>
    <Field Name="Operand" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="PostfixUnaryExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="PostfixUnaryExpression"/>
    <Field Name="Operand" Type="ExpressionSyntax"/>
    <Field Name="OperatorToken" Type="SyntaxToken"/>
  </Node>

  <Node Name="DeleteExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="DeleteExpression"/>
    <Field Name="DeleteKeyword" Type="SyntaxToken">
      <Kind Name="DeleteKeyword"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="TypeOfExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="TypeOfExpression"/>
    <Field Name="TypeOfKeyword" Type="SyntaxToken">
      <Kind Name="TypeOfKeyword"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="VoidExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="VoidExpression"/>
    <Field Name="VoidKeyword" Type="SyntaxToken">
      <Kind Name="VoidKeyword"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="ThisExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="ThisExpression"/>
    <Field Name="ThisKeyword" Type="SyntaxToken">
      <Kind Name="ThisKeyword"/>
    </Field>
  </Node>

  <Node Name="ArgumentSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="Argument"/>
    <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="ArgumentListSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="ArgumentList"/>
    <Field Name="OpenParenToken" Type="SyntaxToken">
        <Kind Name="OpenParenToken"/>
    </Field>
    <Field Name="Arguments" Type="SeparatedSyntaxList&lt;ArgumentSyntax&gt;"/>
    <Field Name="CloseParenToken" Type="SyntaxToken">
        <Kind Name="CloseParenToken"/>
    </Field>
  </Node>

  <Node Name="CallExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="CallExpression"/>
    <Field Name="Expression" Type="ExpressionSyntax"/>
    <Field Name="TypeArguments" Type="TypeArgumentListSyntax" Optional="true"/>
    <Field Name="ArgumentList" Type="ArgumentListSyntax"/>
  </Node>

  <Node Name="NewExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="NewExpression"/>
    <Field Name="NewKeyword" Type="SyntaxToken">
      <Kind Name="NewKeyword"/>
    </Field>
    <Field Name="Type" Type="TypeSyntax"/>
    <Field Name="ArgumentList" Type="ArgumentListSyntax" Optional="true"/>
  </Node>

  <Node Name="ArrayLiteralExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="ArrayLiteralExpression"/>
    <Field Name="OpenBracketToken" Type="SyntaxToken">
      <Kind Name="OpenBracketToken"/>
    </Field>
    <Field Name="Elements" Type="SeparatedSyntaxList&lt;ExpressionSyntax&gt;"/>
    <Field Name="CloseBracketToken" Type="SyntaxToken">
      <Kind Name="CloseBracketToken"/>
    </Field>
  </Node>

  <Node Name="ObjectLiteralExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="ObjectLiteralExpression"/>
    <Field Name="OpenBraceToken" Type="SyntaxToken">
      <Kind Name="OpenBraceToken"/>
    </Field>
    <Field Name="Properties" Type="SeparatedSyntaxList&lt;PropertyAssignmentSyntax&gt;"/>
    <Field Name="CloseBraceToken" Type="SyntaxToken">
      <Kind Name="CloseBraceToken"/>
    </Field>
  </Node>

  <Node Name="ArrowFunctionExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="ArrowFunctionExpression"/>
    <Field Name="AsyncKeyword" Type="SyntaxToken" Optional="true">
      <Kind Name="AsyncKeyword"/>
    </Field>
    <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
    <Field Name="ParameterList" Type="ParameterListSyntax"/>
    <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
    <Field Name="EqualsGreaterThanToken" Type="SyntaxToken">
      <Kind Name="EqualsGreaterThanToken"/>
    </Field>
    <Field Name="Body" Type="TypeScriptSyntaxNode"/>
  </Node>

  <Node Name="AwaitExpressionSyntax" Base="ExpressionSyntax">
    <Kind Name="AwaitExpression"/>
    <Field Name="AwaitKeyword" Type="SyntaxToken">
      <Kind Name="AwaitKeyword"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="PropertyAssignmentSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="PropertyAssignment"/>
    <Field Name="Name" Type="IdentifierNameSyntax"/>
    <Field Name="ColonToken" Type="SyntaxToken">
      <Kind Name="ColonToken"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax"/>
  </Node>

  <!-- Types -->
  <!-- Re-introduce PredefinedTypeSyntax as it's needed for SyntaxFactory override to compile,
       but verify if generator creates it. If I commented it out before, the class doesn't exist. -->
  <Node Name="PredefinedTypeSyntax" Base="TypeSyntax">
    <Kind Name="PredefinedType"/>
    <Field Name="Keyword" Type="SyntaxToken"/>
  </Node>

  <Node Name="TypeReferenceSyntax" Base="TypeSyntax">
    <Kind Name="TypeReference"/>
    <Field Name="TypeName" Type="IdentifierNameSyntax"/>
    <Field Name="TypeArguments" Type="TypeArgumentListSyntax" Optional="true"/>
  </Node>

  <Node Name="ArrayTypeSyntax" Base="TypeSyntax">
    <Kind Name="ArrayType"/>
    <Field Name="ElementType" Type="TypeSyntax"/>
    <Field Name="OpenBracketToken" Type="SyntaxToken">
      <Kind Name="OpenBracketToken"/>
    </Field>
    <Field Name="CloseBracketToken" Type="SyntaxToken">
      <Kind Name="CloseBracketToken"/>
    </Field>
  </Node>

  <Node Name="TypeParameterSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="TypeParameter"/>
    <Field Name="Identifier" Type="SyntaxToken">
      <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="Constraint" Type="TypeParameterConstraintClauseSyntax" Optional="true"/>
    <Field Name="Default" Type="TypeParameterDefaultClauseSyntax" Optional="true"/>
  </Node>

  <Node Name="TypeParameterConstraintClauseSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="TypeParameterConstraintClause"/>
    <Field Name="ExtendsKeyword" Type="SyntaxToken">
      <Kind Name="ExtendsKeyword"/>
    </Field>
    <Field Name="Type" Type="TypeSyntax"/>
  </Node>

  <Node Name="TypeParameterDefaultClauseSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="TypeParameterDefaultClause"/>
    <Field Name="EqualsToken" Type="SyntaxToken">
      <Kind Name="EqualsToken"/>
    </Field>
    <Field Name="Type" Type="TypeSyntax"/>
  </Node>

  <Node Name="TypeParameterListSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="TypeParameterList"/>
    <Field Name="LessThanToken" Type="SyntaxToken">
      <Kind Name="LessThanToken"/>
    </Field>
    <Field Name="Parameters" Type="SeparatedSyntaxList&lt;TypeParameterSyntax&gt;"/>
    <Field Name="GreaterThanToken" Type="SyntaxToken">
      <Kind Name="GreaterThanToken"/>
    </Field>
  </Node>

  <Node Name="TypeArgumentListSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="TypeArgumentList"/>
    <Field Name="LessThanToken" Type="SyntaxToken">
      <Kind Name="LessThanToken"/>
    </Field>
    <Field Name="Arguments" Type="SeparatedSyntaxList&lt;TypeSyntax&gt;"/>
    <Field Name="GreaterThanToken" Type="SyntaxToken">
      <Kind Name="GreaterThanToken"/>
    </Field>
  </Node>

  <Node Name="TypeAnnotationSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="TypeAnnotation"/>
    <Field Name="ColonToken" Type="SyntaxToken">
      <Kind Name="ColonToken"/>
    </Field>
    <Field Name="Type" Type="TypeSyntax"/>
  </Node>

  <!-- Type Elements (Interface Members) -->
  <Node Name="PropertySignatureSyntax" Base="TypeElementSyntax">
    <Kind Name="PropertySignature"/>
    <Field Name="Name" Type="IdentifierNameSyntax"/>
    <Field Name="QuestionToken" Type="SyntaxToken" Optional="true">
        <Kind Name="QuestionToken"/>
    </Field>
    <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <!-- Statements -->
  <Node Name="BlockSyntax" Base="StatementSyntax">
    <Kind Name="Block"/>
    <Field Name="OpenBraceToken" Type="SyntaxToken">
        <Kind Name="OpenBraceToken"/>
    </Field>
    <Field Name="Statements" Type="SyntaxList&lt;StatementSyntax&gt;"/>
    <Field Name="CloseBraceToken" Type="SyntaxToken">
        <Kind Name="CloseBraceToken"/>
    </Field>
  </Node>

  <Node Name="ExpressionStatementSyntax" Base="StatementSyntax">
    <Kind Name="ExpressionStatement"/>
    <Field Name="Expression" Type="ExpressionSyntax"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="ReturnStatementSyntax" Base="StatementSyntax">
    <Kind Name="ReturnStatement"/>
    <Field Name="ReturnKeyword" Type="SyntaxToken">
        <Kind Name="ReturnKeyword"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax" Optional="true"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="EmptyStatementSyntax" Base="StatementSyntax">
    <Kind Name="EmptyStatement"/>
    <Field Name="SemicolonToken" Type="SyntaxToken">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="IfStatementSyntax" Base="StatementSyntax">
    <Kind Name="IfStatement"/>
    <Field Name="IfKeyword" Type="SyntaxToken">
        <Kind Name="IfKeyword"/>
    </Field>
    <Field Name="OpenParenToken" Type="SyntaxToken">
        <Kind Name="OpenParenToken"/>
    </Field>
    <Field Name="Condition" Type="ExpressionSyntax"/>
    <Field Name="CloseParenToken" Type="SyntaxToken">
        <Kind Name="CloseParenToken"/>
    </Field>
    <Field Name="Statement" Type="StatementSyntax"/>
    <Field Name="Else" Type="ElseClauseSyntax" Optional="true"/>
  </Node>

  <Node Name="ElseClauseSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="ElseClause"/>
    <Field Name="ElseKeyword" Type="SyntaxToken">
        <Kind Name="ElseKeyword"/>
    </Field>
    <Field Name="Statement" Type="StatementSyntax"/>
  </Node>

  <Node Name="SwitchStatementSyntax" Base="StatementSyntax">
    <Kind Name="SwitchStatement"/>
    <Field Name="SwitchKeyword" Type="SyntaxToken">
      <Kind Name="SwitchKeyword"/>
    </Field>
    <Field Name="OpenParenToken" Type="SyntaxToken">
      <Kind Name="OpenParenToken"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax"/>
    <Field Name="CloseParenToken" Type="SyntaxToken">
      <Kind Name="CloseParenToken"/>
    </Field>
    <Field Name="OpenBraceToken" Type="SyntaxToken">
      <Kind Name="OpenBraceToken"/>
    </Field>
    <Field Name="Clauses" Type="SyntaxList&lt;SwitchLabelSyntax&gt;"/>
    <Field Name="CloseBraceToken" Type="SyntaxToken">
      <Kind Name="CloseBraceToken"/>
    </Field>
  </Node>

  <AbstractNode Name="SwitchLabelSyntax" Base="TypeScriptSyntaxNode"/>

  <Node Name="CaseClauseSyntax" Base="SwitchLabelSyntax">
    <Kind Name="CaseClause"/>
    <Field Name="CaseKeyword" Type="SyntaxToken">
      <Kind Name="CaseKeyword"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax"/>
    <Field Name="ColonToken" Type="SyntaxToken">
      <Kind Name="ColonToken"/>
    </Field>
    <Field Name="Statements" Type="SyntaxList&lt;StatementSyntax&gt;"/>
  </Node>

  <Node Name="DefaultClauseSyntax" Base="SwitchLabelSyntax">
    <Kind Name="DefaultClause"/>
    <Field Name="DefaultKeyword" Type="SyntaxToken">
      <Kind Name="DefaultKeyword"/>
    </Field>
    <Field Name="ColonToken" Type="SyntaxToken">
      <Kind Name="ColonToken"/>
    </Field>
    <Field Name="Statements" Type="SyntaxList&lt;StatementSyntax&gt;"/>
  </Node>

  <Node Name="TryStatementSyntax" Base="StatementSyntax">
    <Kind Name="TryStatement"/>
    <Field Name="TryKeyword" Type="SyntaxToken">
      <Kind Name="TryKeyword"/>
    </Field>
    <Field Name="Block" Type="BlockSyntax"/>
    <Field Name="CatchClause" Type="CatchClauseSyntax" Optional="true"/>
    <Field Name="FinallyClause" Type="FinallyClauseSyntax" Optional="true"/>
  </Node>

  <Node Name="CatchClauseSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="CatchClause"/>
    <Field Name="CatchKeyword" Type="SyntaxToken">
      <Kind Name="CatchKeyword"/>
    </Field>
    <Field Name="OpenParenToken" Type="SyntaxToken" Optional="true">
      <Kind Name="OpenParenToken"/>
    </Field>
    <Field Name="Declaration" Type="VariableDeclarationSyntax" Optional="true"/>
    <Field Name="CloseParenToken" Type="SyntaxToken" Optional="true">
      <Kind Name="CloseParenToken"/>
    </Field>
    <Field Name="Block" Type="BlockSyntax"/>
  </Node>

  <Node Name="FinallyClauseSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="FinallyClause"/>
    <Field Name="FinallyKeyword" Type="SyntaxToken">
      <Kind Name="FinallyKeyword"/>
    </Field>
    <Field Name="Block" Type="BlockSyntax"/>
  </Node>

  <Node Name="ThrowStatementSyntax" Base="StatementSyntax">
    <Kind Name="ThrowStatement"/>
    <Field Name="ThrowKeyword" Type="SyntaxToken">
      <Kind Name="ThrowKeyword"/>
    </Field>
    <Field Name="Expression" Type="ExpressionSyntax"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
      <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="WhileStatementSyntax" Base="StatementSyntax">
    <Kind Name="WhileStatement"/>
    <Field Name="WhileKeyword" Type="SyntaxToken">
        <Kind Name="WhileKeyword"/>
    </Field>
    <Field Name="OpenParenToken" Type="SyntaxToken">
        <Kind Name="OpenParenToken"/>
    </Field>
    <Field Name="Condition" Type="ExpressionSyntax"/>
    <Field Name="CloseParenToken" Type="SyntaxToken">
        <Kind Name="CloseParenToken"/>
    </Field>
    <Field Name="Statement" Type="StatementSyntax"/>
  </Node>

  <Node Name="DoStatementSyntax" Base="StatementSyntax">
    <Kind Name="DoStatement"/>
    <Field Name="DoKeyword" Type="SyntaxToken">
        <Kind Name="DoKeyword"/>
    </Field>
    <Field Name="Statement" Type="StatementSyntax"/>
    <Field Name="WhileKeyword" Type="SyntaxToken">
        <Kind Name="WhileKeyword"/>
    </Field>
    <Field Name="OpenParenToken" Type="SyntaxToken">
        <Kind Name="OpenParenToken"/>
    </Field>
    <Field Name="Condition" Type="ExpressionSyntax"/>
    <Field Name="CloseParenToken" Type="SyntaxToken">
        <Kind Name="CloseParenToken"/>
    </Field>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="BreakStatementSyntax" Base="StatementSyntax">
    <Kind Name="BreakStatement"/>
    <Field Name="BreakKeyword" Type="SyntaxToken">
        <Kind Name="BreakKeyword"/>
    </Field>
    <Field Name="Label" Type="IdentifierNameSyntax" Optional="true"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="ContinueStatementSyntax" Base="StatementSyntax">
    <Kind Name="ContinueStatement"/>
    <Field Name="ContinueKeyword" Type="SyntaxToken">
        <Kind Name="ContinueKeyword"/>
    </Field>
    <Field Name="Label" Type="IdentifierNameSyntax" Optional="true"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="ForStatementSyntax" Base="StatementSyntax">
    <Kind Name="ForStatement"/>
    <Field Name="ForKeyword" Type="SyntaxToken">
        <Kind Name="ForKeyword"/>
    </Field>
    <Field Name="OpenParenToken" Type="SyntaxToken">
        <Kind Name="OpenParenToken"/>
    </Field>
    <Field Name="Initializer" Type="StatementSyntax" Optional="true"/>
    <Field Name="Condition" Type="ExpressionSyntax" Optional="true"/>
    <Field Name="SecondSemicolonToken" Type="SyntaxToken">
        <Kind Name="SemicolonToken"/>
    </Field>
    <Field Name="Increment" Type="ExpressionSyntax" Optional="true"/>
    <Field Name="CloseParenToken" Type="SyntaxToken">
        <Kind Name="CloseParenToken"/>
    </Field>
    <Field Name="Statement" Type="StatementSyntax"/>
  </Node>

  <Node Name="VariableDeclarationSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="VariableDeclaration"/>
    <Field Name="Identifier" Type="SyntaxToken">
        <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
    <Field Name="EqualsValueClause" Type="EqualsValueClauseSyntax" Optional="true"/>
  </Node>

  <Node Name="EqualsValueClauseSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="EqualsValueClause"/>
    <Field Name="EqualsToken" Type="SyntaxToken">
        <Kind Name="EqualsToken"/>
    </Field>
    <Field Name="Value" Type="ExpressionSyntax"/>
  </Node>

  <Node Name="VariableStatementSyntax" Base="StatementSyntax">
    <Kind Name="VariableStatement"/>
    <Field Name="DeclarationKeyword" Type="SyntaxToken"/> <!-- var, let, const -->
    <Field Name="Declaration" Type="VariableDeclarationSyntax"/> <!-- Simplified: just one for now -->
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="ParameterSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="Parameter"/>
    <Field Name="Identifier" Type="SyntaxToken">
        <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
  </Node>

  <Node Name="ParameterListSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="ParameterList"/>
    <Field Name="OpenParenToken" Type="SyntaxToken">
        <Kind Name="OpenParenToken"/>
    </Field>
    <Field Name="Parameters" Type="SeparatedSyntaxList&lt;ParameterSyntax&gt;"/>
    <Field Name="CloseParenToken" Type="SyntaxToken">
        <Kind Name="CloseParenToken"/>
    </Field>
  </Node>

  <Node Name="TypeAliasDeclarationSyntax" Base="DeclarationStatementSyntax">
    <Kind Name="TypeAliasDeclaration"/>
    <Field Name="TypeKeyword" Type="SyntaxToken">
      <Kind Name="TypeKeyword"/>
    </Field>
    <Field Name="Identifier" Type="SyntaxToken">
      <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
    <Field Name="EqualsToken" Type="SyntaxToken">
      <Kind Name="EqualsToken"/>
    </Field>
    <Field Name="Type" Type="TypeSyntax"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
      <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="EnumDeclarationSyntax" Base="DeclarationStatementSyntax">
    <Kind Name="EnumDeclaration"/>
    <Field Name="EnumKeyword" Type="SyntaxToken">
      <Kind Name="EnumKeyword"/>
    </Field>
    <Field Name="Identifier" Type="SyntaxToken">
      <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="OpenBraceToken" Type="SyntaxToken">
      <Kind Name="OpenBraceToken"/>
    </Field>
    <Field Name="Members" Type="SeparatedSyntaxList&lt;EnumMemberSyntax&gt;"/>
    <Field Name="CloseBraceToken" Type="SyntaxToken">
      <Kind Name="CloseBraceToken"/>
    </Field>
  </Node>

  <Node Name="EnumMemberSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="EnumMember"/>
    <Field Name="Identifier" Type="SyntaxToken">
      <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="EqualsValueClause" Type="EqualsValueClauseSyntax" Optional="true"/>
  </Node>

  <Node Name="FunctionDeclarationSyntax" Base="DeclarationStatementSyntax">
    <Kind Name="FunctionDeclaration"/>
    <Field Name="AsyncKeyword" Type="SyntaxToken" Optional="true">
      <Kind Name="AsyncKeyword"/>
    </Field>
    <Field Name="FunctionKeyword" Type="SyntaxToken">
      <Kind Name="FunctionKeyword"/>
    </Field>
    <Field Name="Identifier" Type="SyntaxToken" Optional="true">
      <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
    <Field Name="ParameterList" Type="ParameterListSyntax"/>
    <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
    <Field Name="Body" Type="BlockSyntax" Optional="true"/>
  </Node>

  <Node Name="InterfaceDeclarationSyntax" Base="DeclarationStatementSyntax">
    <Kind Name="InterfaceDeclaration"/>
    <Field Name="InterfaceKeyword" Type="SyntaxToken">
      <Kind Name="InterfaceKeyword"/>
    </Field>
    <Field Name="Identifier" Type="SyntaxToken">
      <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
    <Field Name="OpenBraceToken" Type="SyntaxToken">
      <Kind Name="OpenBraceToken"/>
    </Field>
    <Field Name="Members" Type="SyntaxList&lt;TypeElementSyntax&gt;"/>
    <Field Name="CloseBraceToken" Type="SyntaxToken">
      <Kind Name="CloseBraceToken"/>
    </Field>
  </Node>

  <Node Name="ClassDeclarationSyntax" Base="DeclarationStatementSyntax">
    <Kind Name="ClassDeclaration"/>
    <Field Name="ClassKeyword" Type="SyntaxToken">
      <Kind Name="ClassKeyword"/>
    </Field>
    <Field Name="Identifier" Type="SyntaxToken" Optional="true">
      <Kind Name="IdentifierToken"/>
    </Field>
    <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
    <Field Name="OpenBraceToken" Type="SyntaxToken">
      <Kind Name="OpenBraceToken"/>
    </Field>
    <Field Name="Members" Type="SyntaxList&lt;ClassElementSyntax&gt;"/>
    <Field Name="CloseBraceToken" Type="SyntaxToken">
      <Kind Name="CloseBraceToken"/>
    </Field>
  </Node>

  <Node Name="MethodDeclarationSyntax" Base="ClassElementSyntax">
    <Kind Name="MethodDeclaration"/>
    <Field Name="AsyncKeyword" Type="SyntaxToken" Optional="true">
      <Kind Name="AsyncKeyword"/>
    </Field>
    <Field Name="Name" Type="IdentifierNameSyntax"/>
    <Field Name="TypeParameters" Type="TypeParameterListSyntax" Optional="true"/>
    <Field Name="ParameterList" Type="ParameterListSyntax"/>
    <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
    <Field Name="Body" Type="BlockSyntax" Optional="true"/>
  </Node>

  <Node Name="PropertyDeclarationSyntax" Base="ClassElementSyntax">
    <Kind Name="PropertyDeclaration"/>
    <Field Name="Name" Type="IdentifierNameSyntax"/>
    <Field Name="TypeAnnotation" Type="TypeAnnotationSyntax" Optional="true"/>
    <Field Name="EqualsValueClause" Type="EqualsValueClauseSyntax" Optional="true"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
        <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="ConstructorDeclarationSyntax" Base="ClassElementSyntax">
    <Kind Name="ConstructorDeclaration"/>
    <Field Name="ConstructorKeyword" Type="SyntaxToken">
        <Kind Name="ConstructorKeyword"/>
    </Field>
    <Field Name="ParameterList" Type="ParameterListSyntax"/>
    <Field Name="Body" Type="BlockSyntax" Optional="true"/>
  </Node>

  <!-- Module Imports -->
  <Node Name="ImportDeclarationSyntax" Base="StatementSyntax">
    <Kind Name="ImportDeclaration"/>
    <Field Name="ImportKeyword" Type="SyntaxToken">
      <Kind Name="ImportKeyword"/>
    </Field>
    <Field Name="ImportClause" Type="ImportClauseSyntax" Optional="true"/>
    <Field Name="FromKeyword" Type="SyntaxToken" Optional="true">
      <Kind Name="FromKeyword"/>
    </Field>
    <Field Name="ModuleSpecifier" Type="ExpressionSyntax"/>
    <Field Name="SemicolonToken" Type="SyntaxToken" Optional="true">
      <Kind Name="SemicolonToken"/>
    </Field>
  </Node>

  <Node Name="ImportClauseSyntax" Base="TypeScriptSyntaxNode">
    <Kind Name="ImportClause"/>
    <Field Name="Name" Type="IdentifierNameSyntax" Optional="true"/>
    <Field Name="CommaToken" Type="SyntaxToken" Optional="true">
      <Kind Name="CommaToken"/>
    </Field>
    <Field Name="NamedBindings" Type="NamedImportBindingsSyntax" Optional="true"/>
  </Node>

  <AbstractNode Name="NamedImportBindingsSyntax" Base="TypeScriptSyntaxNode"/>

  <Node Name="NamespaceImportSyntax" Base="NamedImportBindingsSyntax">
    <Kind Name="NamespaceImport"/>
    <Field Name="AsteriskToken" Type="SyntaxToken">
      <Kind Name="AsteriskToken"/>
    </Field>
